{
    "name": "zwave-monorepo",
    "version": "1.1.0",
    "private": true,
    "type": "module",
    "description": "Z-Wave controller service + web UI monorepo",
    "engines": {
        "node": ">=20.0.0"
    },
    "workspaces": [
        "packages/contracts",
        "packages/service",
        "packages/web"
    ],
    "scripts": {
        "build": "npm run build:service && npm run build -w @zwave-service/web",
        "build:contracts": "npm run build -w @zwave-service/contracts",
        "build:service": "npm run build:contracts && npm run build:schemas -w @zwave-service/service && npm run build -w @zwave-service/service",
        "build:web": "npm run build:contracts && npm run build -w @zwave-service/web",
        "lint": "eslint .",
        "clean": "npm run clean --workspaces --if-present && ./.scripts/clean-all.sh",
        "dev:service": "npm run dev -w @zwave-service/service",
        "dev:web": "npm run dev -w @zwave-service/web",
        "dockerbuild": "node ./.scripts/dockerBuild.cjs -b -p",
        "dockerpush": "node ./.scripts/dockerBuild.cjs -p"
    },
    "keywords": [
        "automation",
        "iot",
        "zwave"
    ],
    "author": "sseiber",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git@github.com:sseiber/zwave-service.git"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.2",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/node": "^26.1.1",
        "eslint": "^9.39.2",
        "globals": "^17.3.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.0"
    }
}

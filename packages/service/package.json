{
    "name": "@zwave-service/service",
    "version": "1.3.0",
    "type": "module",
    "description": "Z-Wave controller service for Raspberry Pi",
    "main": "dist/index.js",
    "scripts": {
        "start": "node dist/index.js",
        "build": "tsc --build --verbose",
        "build:all": "tsc --build --force --verbose",
        "build:schemas": "rm -f ./src/models/schemas/*.json && node ./.scripts/buildTypeSchemas.cjs --types-file ../../contracts/src/zwaveTypes.ts",
        "lint": "eslint .",
        "clean": "tsc --build --clean"
    },
    "dependencies": {
        "@fastify/autoload": "^6.4.0",
        "@fastify/sensible": "^6.0.4",
        "@fastify/static": "^8.1.1",
        "@zwave-js/core": "^15.25.3",
        "@zwave-service/contracts": "*",
        "env-schema": "^7.0.0",
        "fastify": "^5.10.0",
        "fastify-plugin": "^6.0.0",
        "fs-extra": "^11.3.6",
        "pino-pretty": "^13.1.3",
        "suncalc": "^2.0.1",
        "uuid": "^14.0.1",
        "zwave-js": "^15.25.3"
    },
    "devDependencies": {
        "@types/fs-extra": "^11.0.4",
        "@types/suncalc": "^1.9.2",
        "commander": "15.0.0",
        "ts-json-schema-generator": "^2.5.0"
    }
}

{
  "$id": "ISchedule",
  "$ref": "#/definitions/ISchedule",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "ISchedule": {
      "additionalProperties": false,
      "properties": {
        "at": {
          "type": "string"
        },
        "daysOfMonth": {
          "items": {
            "type": "number"
          },
          "type": "array"
        },
        "daysOfWeek": {
          "items": {
            "type": "number"
          },
          "type": "array"
        },
        "every": {
          "type": "number"
        },
        "kind": {
          "$ref": "#/definitions/ScheduleKind"
        },
        "timeOfDay": {
          "$ref": "#/definitions/ITimeOfDay"
        },
        "unit": {
          "$ref": "#/definitions/IntervalUnit"
        }
      },
      "required": [
        "kind"
      ],
      "type": "object"
    },
    "ITimeOfDay": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/definitions/TimeOfDayKind"
        },
        "offsetMinutes": {
          "type": "number"
        },
        "time": {
          "type": "string"
        }
      },
      "required": [
        "kind"
      ],
      "type": "object"
    },
    "IntervalUnit": {
      "enum": [
        "seconds",
        "minutes",
        "hours",
        "days"
      ],
      "type": "string"
    },
    "ScheduleKind": {
      "enum": [
        "interval",
        "daily",
        "weekly",
        "monthly",
        "once"
      ],
      "type": "string"
    },
    "TimeOfDayKind": {
      "enum": [
        "clock",
        "sunrise",
        "sunset"
      ],
      "type": "string"
    }
  }
}
{
  "$id": "IDeviceInfo",
  "$ref": "#/definitions/IDeviceInfo",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "DeviceStatus": {
      "enum": [
        "unknown",
        "asleep",
        "awake",
        "dead",
        "alive"
      ],
      "type": "string"
    },
    "DeviceType": {
      "enum": [
        "switch",
        "dimmer",
        "unknown"
      ],
      "type": "string"
    },
    "IDeviceBattery": {
      "additionalProperties": false,
      "properties": {
        "isLow": {
          "type": "boolean"
        },
        "level": {
          "type": "number"
        }
      },
      "type": "object"
    },
    "IDeviceInfo": {
      "additionalProperties": false,
      "properties": {
        "battery": {
          "$ref": "#/definitions/IDeviceBattery"
        },
        "firmwareVersion": {
          "type": "string"
        },
        "level": {
          "type": "number"
        },
        "link": {
          "$ref": "#/definitions/IDeviceLink"
        },
        "location": {
          "type": "string"
        },
        "manufacturer": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "nodeId": {
          "type": "number"
        },
        "on": {
          "type": "boolean"
        },
        "power": {
          "$ref": "#/definitions/IDevicePower"
        },
        "product": {
          "type": "string"
        },
        "ready": {
          "type": "boolean"
        },
        "securityClass": {
          "type": "string"
        },
        "status": {
          "$ref": "#/definitions/DeviceStatus"
        },
        "targetLevel": {
          "type": "number"
        },
        "type": {
          "$ref": "#/definitions/DeviceType"
        }
      },
      "required": [
        "nodeId",
        "name",
        "location",
        "type",
        "status",
        "ready"
      ],
      "type": "object"
    },
    "IDeviceLink": {
      "additionalProperties": false,
      "properties": {
        "hops": {
          "type": "number"
        },
        "lastSeen": {
          "type": "string"
        },
        "rssi": {
          "type": "number"
        },
        "rtt": {
          "type": "number"
        }
      },
      "type": "object"
    },
    "IDevicePower": {
      "additionalProperties": false,
      "properties": {
        "amps": {
          "type": "number"
        },
        "kWh": {
          "type": "number"
        },
        "volts": {
          "type": "number"
        },
        "watts": {
          "type": "number"
        }
      },
      "type": "object"
    }
  }
}
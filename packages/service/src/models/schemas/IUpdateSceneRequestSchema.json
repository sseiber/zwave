{
  "$id": "IUpdateSceneRequest",
  "$ref": "#/definitions/IUpdateSceneRequest",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "DeviceAction": {
      "enum": [
        "on",
        "off",
        "dim"
      ],
      "type": "string"
    },
    "ISceneDevice": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "$ref": "#/definitions/DeviceAction"
        },
        "deviceId": {
          "type": "number"
        },
        "level": {
          "type": "number"
        }
      },
      "required": [
        "deviceId",
        "action"
      ],
      "type": "object"
    },
    "IUpdateSceneRequest": {
      "additionalProperties": false,
      "properties": {
        "devices": {
          "items": {
            "$ref": "#/definitions/ISceneDevice"
          },
          "type": "array"
        },
        "name": {
          "type": "string"
        },
        "roomId": {
          "type": "string"
        },
        "trigger": {
          "$ref": "#/definitions/SceneTrigger"
        }
      },
      "type": "object"
    },
    "SceneTrigger": {
      "enum": [
        "manual",
        "scheduled"
      ],
      "type": "string"
    }
  }
}